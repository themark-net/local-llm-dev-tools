SMOKE_ID=repowise
SMOKE_DATE=2026-07-12
# Pin PyPI version used for in-cage smoke (tools.json previously "latest-pypi-pin-on-eval")
REPOWISE_PIP_SPEC=repowise==0.30.0
UPSTREAM=https://github.com/repowise-dev/repowise
# Cage agent image has Python 3.12 — required (host 3.14 cannot install current repowise deps)
PYTHON_IN_CAGE=3.12
FIXTURE_PATH=/workspace/examples/repowise/fixture
# health: zero LLM, builds graph in-process
SMOKE_CMD=health
